---
import BaseLayout from '../../layouts/BaseLayout.astro';

const skills = [
  { category: 'Frontend', items: ['HTML5 / CSS3', 'JavaScript (ES6+)', 'TypeScript', 'React / Next.js', 'Vue.js', 'Astro'] },
  { category: 'Design', items: ['Figma', 'UI/UX Design', 'Responsive Design', 'Design Systems'] },
  { category: 'Tools', items: ['Git / GitHub', 'Vercel', 'VS Code', 'Cursor'] },
  { category: 'Other', items: ['Node.js', 'Python', 'RESTful APIs', 'SEO'] }
];

const experiences = [
  {
    period: '2023 - Present',
    titleEn: 'Freelance Designer & Developer',
    titleCn: '自由设计师与开发者',
    desc: '独立承接 Web 设计与开发项目，专注于极简主义设计与高性能网站构建。'
  },
  {
    period: '2021 - 2023',
    titleEn: 'Frontend Developer',
    titleCn: '前端开发工程师',
    desc: '参与多个企业级项目的前端开发，负责界面实现与用户体验优化。'
  }
];
---

<BaseLayout title="About | Dar1an" description="关于 Dar1an - UI/UX 设计师与前端开发者">
  <div class="page-content about-page">
    <!-- 个人简介 -->
    <section class="about-hero">
      <div class="about-intro">
        <h1 class="page-title">
          <span class="en">About Me</span>
          <span class="cn">关于我</span>
        </h1>
        <div class="about-text">
          <p class="lead">
            <span class="en">I'm a designer and developer who believes in the power of simplicity.</span>
            <span class="cn">我是一个相信简约力量的设计师和开发者。</span>
          </p>
          <p>
            我专注于创造既美观又实用的数字体验。无论是从零开始构建一个网站，还是为现有产品改进用户界面，
            我都致力于在设计与功能之间找到完美的平衡点。
          </p>
          <p>
            除了工作，我喜欢探索新技术、撰写技术博客，以及在数字花园中整理我的知识体系。
          </p>
        </div>
        <div class="about-actions">
          <a href="mailto:hwe2377@gmail.com" class="btn-primary">
            <span class="en">Get in Touch</span>
            <span class="cn">联系我</span>
          </a>
          <a href="/portfolio/" class="btn-secondary">
            <span class="en">View Works</span>
            <span class="cn">查看作品</span>
          </a>
        </div>
      </div>
      <div class="about-image">
        <img src="https://img.dar1an.dpdns.org/Picgo/2025/12-02-20-24-54.png" alt="Dar1an">
      </div>
    </section>

    <!-- 技能板块 -->
    <section class="skills-section">
      <h2 class="section-heading">
        <span class="en">Skills & Tools</span>
        <span class="cn">技能与工具</span>
      </h2>
      <div class="skills-grid">
        {skills.map(skill => (
          <div class="skill-card">
            <h3 class="skill-category">{skill.category}</h3>
            <ul class="skill-list">
              {skill.items.map(item => (
                <li class="skill-item">{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- 经历板块 -->
    <section class="experience-section">
      <h2 class="section-heading">
        <span class="en">Experience</span>
        <span class="cn">工作经历</span>
      </h2>
      <div class="timeline">
        {experiences.map(exp => (
          <div class="timeline-item">
            <div class="timeline-period">{exp.period}</div>
            <div class="timeline-content">
              <h3 class="timeline-title">
                <span class="en">{exp.titleEn}</span>
                <span class="cn">{exp.titleCn}</span>
              </h3>
              <p class="timeline-desc">{exp.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .about-page {
    padding: 180px 10% 100px;
    padding-left: 140px;
    max-width: 1200px;
  }

  /* Hero Section */
  .about-hero {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 80px;
    align-items: center;
    margin-bottom: 120px;
  }

  .page-title {
    font-size: 3rem;
    font-weight: 300;
    margin-bottom: 40px;
    line-height: 1.2;
  }

  .page-title .cn {
    font-size: 1.2rem;
    color: var(--text-muted);
    margin-top: 10px;
  }

  .about-text p {
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 20px;
    font-size: 1.05rem;
  }

  .about-text .lead {
    font-size: 1.3rem;
    color: var(--text-main);
    margin-bottom: 30px;
  }

  .about-text .lead .cn {
    display: block;
    font-size: 1.1rem;
    margin-top: 8px;
    color: #aaa;
  }

  .about-actions {
    display: flex;
    gap: 20px;
    margin-top: 40px;
  }

  .btn-primary, .btn-secondary {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    padding: 12px 30px;
    border-radius: 50px;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .btn-primary {
    background: var(--text-main);
    color: var(--bg-color);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(255,255,255,0.1);
  }

  .btn-secondary {
    border: 1px solid rgba(255,255,255,0.3);
  }

  .btn-secondary:hover {
    border-color: var(--text-main);
    background: rgba(255,255,255,0.05);
  }

  .btn-primary .en, .btn-secondary .en {
    font-size: 0.9rem;
    font-weight: 600;
  }

  .btn-primary .cn, .btn-secondary .cn {
    font-size: 0.75rem;
    margin-top: 2px;
  }

  .btn-primary .cn { color: #555; }
  .btn-secondary .cn { color: var(--text-muted); }

  .about-image {
    position: relative;
  }

  .about-image img {
    width: 100%;
    max-width: 400px;
    border-radius: 12px;
    filter: grayscale(100%) brightness(0.9);
    transition: all 0.5s ease;
  }

  .about-image:hover img {
    filter: grayscale(0%) brightness(1);
  }

  /* Skills Section */
  .skills-section {
    margin-bottom: 120px;
  }

  .section-heading {
    font-size: 2rem;
    font-weight: 300;
    margin-bottom: 50px;
  }

  .section-heading .cn {
    display: block;
    font-size: 1rem;
    color: var(--text-muted);
    margin-top: 8px;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 30px;
  }

  .skill-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 12px;
    padding: 30px;
    transition: all 0.3s ease;
  }

  .skill-card:hover {
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.15);
    transform: translateY(-5px);
  }

  .skill-category {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 20px;
  }

  .skill-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .skill-item {
    color: var(--text-main);
    font-size: 1rem;
    padding-left: 20px;
    position: relative;
  }

  .skill-item::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--text-muted);
  }

  /* Experience Section */
  .experience-section {
    margin-bottom: 60px;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 150px 1fr;
    gap: 40px;
    padding: 30px;
    background: rgba(255,255,255,0.02);
    border-radius: 12px;
    border-left: 3px solid rgba(255,255,255,0.1);
    transition: all 0.3s ease;
  }

  .timeline-item:hover {
    background: rgba(255,255,255,0.04);
    border-left-color: var(--text-main);
  }

  .timeline-period {
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 500;
  }

  .timeline-title {
    font-size: 1.2rem;
    font-weight: 500;
    margin-bottom: 10px;
  }

  .timeline-title .cn {
    display: block;
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-top: 5px;
    font-weight: 400;
  }

  .timeline-desc {
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .about-page {
      padding: 120px 5% 100px;
    }

    .about-hero {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .page-title {
      font-size: 2rem;
    }

    .about-actions {
      flex-direction: column;
    }

    .about-image img {
      max-width: 100%;
    }

    .timeline-item {
      grid-template-columns: 1fr;
      gap: 15px;
    }

    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
