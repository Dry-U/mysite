---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Dar1an | Portfolio and others',
  description = 'UI/UX Designer \& Developer - Exploring the boundaries between design and code.'
} = Astro.props;

const navItems = [
  { id: 'home', en: 'Home', cn: '主页', url: '/#home' },
  { id: 'blog', en: 'Blog', cn: '博客', url: '/blog/' },
  { id: 'portfolio', en: 'Works', cn: '作品', url: '/portfolio/' },
  { id: 'share', en: 'Share', cn: '分享', url: '/share/' }
];
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css">
  <style is:global>
    @import '../styles/global.css';
  </style>
</head>
<body>
  <!-- Navigation -->
  <header id="navbar">
    <a href="/" class="logo">
      <img src="https://img.dar1an.dpdns.org/Picgo/2025/12-02-20-24-54.png" alt="Avatar">
      <span>Dar1an</span>
    </a>
    <nav class="nav-links">
      {navItems.map(item => (
        <a
          href={item.url}
          class={`nav-anchor ${item.id === 'home' && Astro.url.pathname === '/' ? 'active' : ''}`}
          data-target={item.id}
        >
          <div class="nav-link-item">
            <span class="en">{item.en}</span>
            <span class="cn">{item.cn}</span>
          </div>
        </a>
      ))}
    </nav>
  </header>

  <!-- Sidebar Social -->
  <aside class="sidebar-social">
    <a href="https://github.com/Dry-U" target="_blank" class="social-btn" aria-label="GitHub">
      <i class="ri-github-fill"></i>
    </a>
    <a href="https://x.com/Dar1an12?s=09" target="_blank" class="social-btn" aria-label="X/Twitter">
      <i class="ri-twitter-x-line"></i>
    </a>
    <a href="https://www.douyin.com/user/MS4wLjABAAAAErKu8J3wa7xio2BqmIjNznDI3i5UZaXQRAzH9EpOR9Y?from_tab_name=main" target="_blank" class="social-btn" aria-label="Douyin">
      <i class="ri-tiktok-line"></i>
    </a>
    <div class="social-btn email-container" onclick="copyEmail()">
      <i class="ri-mail-line"></i>
      <span class="email-text">hwe2377@gmail.com (Click to Copy)</span>
    </div>
  </aside>

  <!-- Copy Toast -->
  <div id="copy-toast">邮箱已复制 / Email Copied</div>

  <!-- Main Content -->
  <main>
    <slot />
  </main>

  <script>
    // Navbar scroll effect
    const header = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        header?.classList.add('scrolled');
      } else {
        header?.classList.remove('scrolled');
      }
    });

    // Email copy function
    function copyEmail() {
      const email = "hwe2377@gmail.com";
      navigator.clipboard.writeText(email).then(() => {
        const toast = document.getElementById('copy-toast');
        if (toast) {
          toast.style.opacity = '1';
          toast.style.top = '40%';
          setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.top = '50%';
          }, 2000);
        }
      }).catch(err => {
        console.error('Copy failed:', err);
      });
    }

    // Make copyEmail available globally
    (window as any).copyEmail = copyEmail;
  </script>
</body>
</html>
